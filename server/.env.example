# Copy to .env for local dev (loaded by your shell, or set in Render dashboard).

# Port the server listens on (Render sets this automatically).
PORT=3000

# Where the SQLite database file lives.
# Local: defaults to ./data. Render: set to the persistent disk mount, e.g. /var/data
DATA_DIR=./data

# Allowed CORS origins for the dashboard. "*" allows all (fine when the API
# also serves the dashboard). For a separately hosted dashboard, set its URL:
# CORS_ORIGIN=https://my-dashboard.onrender.com
CORS_ORIGIN=*

# Optional: override where the static dashboard is served from.
# WEB_DIR=../web

# --- Auth ---
# Secret used to sign session cookies. If unset, a random secret is generated and
# stored in the DB (so logins survive restarts). Set it explicitly to share across instances.
# SESSION_SECRET=change-me-to-a-long-random-string

# Google Sign-In: create an OAuth 2.0 Client ID (type "Web application") in Google
# Cloud Console, add your site to "Authorized JavaScript origins"
# (e.g. https://blueskies-cevr.onrender.com and http://localhost:3000), and paste
# the Client ID here. Leave empty to hide the Google button (email/password still works).
# GOOGLE_CLIENT_ID=xxxxx.apps.googleusercontent.com
